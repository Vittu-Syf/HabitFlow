generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  passwordHash  String
  profileImage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  habits Habit[]
}

model Habit {
  id              Int      @id @default(autoincrement())
  userId          Int

  name            String
  description     String?

  icon            String?
  color           String?

  frequency       Frequency

  targetPerPeriod Int?

  isActive        Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  checks HabitCheck[]
  goal   Goal?
}

model HabitCheck {
  id          Int      @id @default(autoincrement())
  habitId     Int

  completedAt DateTime

  habit Habit @relation(fields: [habitId], references: [id])
}

model Goal {
  id           Int      @id @default(autoincrement())

  habitId      Int      @unique

  targetValue  Int
  currentValue Int      @default(0)

  createdAt    DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id])
}